@using System.Globalization
@model Amrod_E_Commerce.Data.Entities.Product

<div class="card shadow-sm border-0 overflow-hidden product-card d-flex flex-column w-100 position-relative"
     data-id="@Model.Id"
     style="cursor: pointer; transition: transform 0.2s;">

    <!-- Image -->
    <div class="product-image-container">
        <img src="@Model.ImageURL" alt="@Model.Name">

        @if (Model.Stock <= 5 && Model.Stock > 0)
        {
            <span class="badge bg-warning position-absolute top-0 end-0 m-2">Low Stock</span>
        }
        else if (Model.Stock == 0)
        {
            <span class="badge bg-danger position-absolute top-0 end-0 m-2">Out of Stock</span>
        }
        else
        {
            <span class="badge bg-success position-absolute top-0 end-0 m-2">In Stock</span>
        }
    </div>

    <div class="card-body d-flex flex-column p-3">

        <h5 class="card-title mb-2" style="font-weight: 600;">
            @Model.Name
        </h5>

        <p class="card-text mb-3 product-description"
           title="@Model.Description">
            @Model.Description
        </p>

        <div class="mt-auto">
            <p class="fw-bold fs-5 mb-2 text-primary">
                @Model.Price.ToString("C", CultureInfo.GetCultureInfo("en-ZA"))
            </p>

            <button data-product-id="@Model.Id"
                    @(Model.Stock <= 0 ? "disabled" : "")
                    class="btn btn-primary btn-sm w-100 btn-add-to-cart">
                Add to Cart
            </button>
        </div>

    </div>
</div>

<style>
    .product-card {
        height: 100%;
        display: flex;
        flex-direction: column;
        transition: transform 0.2s;
    }

    .product-image-container {
        height: 600px;
        overflow: hidden;
    }

    .product-image-container img {
        width: 100%;
        height: 100%;
        object-fit: cover; 
    }

    .product-card:hover {
        transform: translateY(-5px);
    }

    .product-card img {
        width: 100%;
        height: 100%;
        object-fit: cover; 
    }

    .product-card:hover img {
        transform: scale(1.05);
    }
</style>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).on('click', '.btn-add-to-cart', function (e) {
        e.preventDefault();
        e.stopPropagation();
        e.stopImmediatePropagation();

        const $btn = $(this);
        $btn.prop('disabled', true).text('Adding...');

        const productId = $(this).data('product-id');

        fetch(`/api/cart/AddItem?productId=${productId}&quantity=1`, {
            method: 'POST',
            credentials: 'include'
        })
        .then(async res => {

            if (res.redirected) {
                window.location.href = res.url;
                return;
            }

            if (res.status === 401) {
                window.location.href = '/User/Login';
                return;
            }

            if (!res.ok) {
                const text = await res.text();
                throw new Error(text);
            }

            return res.json();
        })
        .then(data => {
            if (!data) return;

            alert("Item added to cart!");
            $btn.prop('disabled', false).text('Add to Cart');

            document.dispatchEvent(new CustomEvent('cart_items_updated'))
        })
        .catch(err => {
            console.error(err);
            alert(err.message);
            $btn.prop('disabled', false).text('Add to Cart');
        });
    });
</script>