@model Amrod_E_Commerce.Data.Entities.Product

<div class="card h-100 shadow-sm">
    <img src="@Model.ImageURL" class="card-img-top" alt="@Model.Name" style="object-fit: cover; height: 200px;">
    <div class="card-body d-flex flex-column">
        <h5 class="card-title">@Model.Name</h5>
        <p class="card-text text-truncate" title="@Model.Description">@Model.Description</p>
        <div class="mt-auto">
            <p class="fw-bold mb-2">$@Model.Price</p>
            <p class="text-muted mb-2">
                @if (Model.Stock > 0)
                {
                    <span>In Stock</span>
                }
                else
                {
                    <span>Out of Stock</span>
                }
            </p>
            <a href="#" class="btn btn-primary w-100">Add to Cart</a>
        </div>
    </div>
</div>