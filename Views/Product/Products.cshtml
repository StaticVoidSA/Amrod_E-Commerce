@model Amrod_E_Commerce.ViewModels.PagedResult<Amrod_E_Commerce.Data.Entities.Product>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Products";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/js/bootstrap.bundle.min.js"></script>

<div class="container my-1">
    <h2 class="text-center mb-4">Our Products</h2>

    <div class="row align-items-center g-3 mb-4">
        <div class="row align-items-center g-3 mb-4">
            <div class="col-12">
                <form id="filterForm" class="d-flex flex-wrap align-items-center gap-2">
                    <!-- Search -->
                    <div class="flex-grow-1 flex-shrink-1" style="min-width: 150px;">
                        <input type="text" name="searchTerm" value="@ViewData["CurrentSearch"]" class="form-control" placeholder="Search products...">
                    </div>

                    <!-- Min Price -->
                    <div class="flex-grow-1 flex-shrink-1" style="min-width: 100px;">
                        <input type="number" step="0.01" name="minPrice" value="@ViewData["MinPrice"]" class="form-control" placeholder="Min Price">
                    </div>

                    <!-- Max Price -->
                    <div class="flex-grow-1 flex-shrink-1" style="min-width: 100px;">
                        <input type="number" step="0.01" name="maxPrice" value="@ViewData["MaxPrice"]" class="form-control" placeholder="Max Price">
                    </div>

                    <!-- Min Stock -->
                    <div class="flex-grow-1 flex-shrink-1" style="min-width: 100px;">
                        <input type="number" name="minStock" value="@ViewData["MinStock"]" class="form-control" placeholder="Min Stock">
                    </div>

                    <!-- Max Stock -->
                    <div class="flex-grow-1 flex-shrink-1" style="min-width: 100px;">
                        <input type="number" name="maxStock" value="@ViewData["MaxStock"]" class="form-control" placeholder="Max Stock">
                    </div>

                    <!-- Order By -->
                    <div class="flex-grow-1 flex-shrink-1" style="min-width: 100px;">
                        <select name="orderBy" class="form-select">
                            <option value="">Order By</option>
                            <option value="price" @(ViewData["OrderBy"]?.ToString() == "price" ? "selected" : "")>Price</option>
                            <option value="name" @(ViewData["OrderBy"]?.ToString() == "name" ? "selected" : "")>Name</option>
                            <option value="stock" @(ViewData["OrderBy"]?.ToString() == "stock" ? "selected" : "")>Stock</option>
                        </select>
                    </div>

                    <!-- Ascending / Descending -->
                    <div class="flex-grow-1 flex-shrink-1" style="min-width: 100px;">
                        <select name="ascending" class="form-select">
                            <option value="true" @(ViewData["Ascending"]?.ToString() == "True" ? "selected" : "")>Ascending</option>
                            <option value="false" @(ViewData["Ascending"]?.ToString() == "False" ? "selected" : "")>Descending</option>
                        </select>
                    </div>

                    <!-- Submit Button -->
                    <div class="ms-auto" style="min-width: 120px;">
                        <button type="submit" class="btn btn-primary w-100">Apply Filters</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Product Grid -->
    <div id="product-grid" class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 g-3">
        @await Html.PartialAsync("_ProductGridItems", Model.Items)
    </div>

    <!-- Pagination -->
    <div class="d-flex align-items-center mt-4 flex-wrap gap-3">
        <!-- Pagination -->
        <nav aria-label="Product pagination" class="d-flex align-items-center">
            <ul class="pagination mb-0" id="pagination">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link" href="#" data-page="@i">@i</a>
                    </li>
                }
            </ul>

            <!-- Showing info next to pagination -->
            <div class="text-muted small ms-3">
                Showing @ViewData["ShowingFrom"] - @ViewData["ShowingTo"] of @ViewData["TotalItems"] products
            </div>
        </nav>

        <!-- Page Size -->
        <div class="d-flex align-items-center gap-2 ms-auto">
            <label class="form-label mb-0 text-muted small">Page Size:</label>
            <select id="pageSize" class="form-select form-select-sm w-auto">
                <option value="10" @(ViewData["PageSize"]?.ToString() == "10" ? "selected" : "")>10</option>
                <option value="25" @(ViewData["PageSize"]?.ToString() == "25" || string.IsNullOrEmpty(ViewData["PageSize"]?.ToString()) ? "selected" : "")>25</option>
                <option value="50" @(ViewData["PageSize"]?.ToString() == "50" ? "selected" : "")>50</option>
                <option value="100" @(ViewData["PageSize"]?.ToString() == "100" ? "selected" : "")>100</option>
            </select>
        </div>

        <!-- Modal Overlays -->
        <div class="modal fade" id="productOverlay" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered" style="max-width: 25vw; max-height: 25vh;">
                <div class="modal-content" style="height: 100%; width: 100%;">
                    <div class="modal-body p-0" style="overflow: hidden;">
                        <!-- Modal content will be loaded here -->
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    const baseUrl = '@Url.Action("GetAllProducts", "Product")';

    function loadProducts(pageNumber) {
        const query = {
            pageNumber: pageNumber,
            pageSize: $('#pageSize').val(),
            searchTerm: $('input[name="searchTerm"]').val() || '',
            minPrice: $('input[name="minPrice"]').val() || '',
            maxPrice: $('input[name="maxPrice"]').val() || '',
            minStock: $('input[name="minStock"]').val() || '',
            maxStock: $('input[name="maxStock"]').val() || '',
            orderBy: $('select[name="orderBy"]').val() || '',
            ascending: $('select[name="ascending"]').val() === "true" // convert to boolean
        };

        $.get(baseUrl, query)
            .done(function (data) {
                $("#product-grid").html(data);
                refreshPagination(pageNumber);
            })
            .fail(function () {
                alert("Failed to load products.");
            });
    }

    function refreshPagination(currentPage) {
        const orderBy = $('select[name="orderBy"]').val() || '';
        const ascending = $('select[name="ascending"]').val() || 'true'; 

        window.location.href = `${baseUrl}?pageNumber=${currentPage}&pageSize=${$('#pageSize').val()}`
            + `&searchTerm=${encodeURIComponent($('input[name="searchTerm"]').val() || '')}`
            + `&minPrice=${$('input[name="minPrice"]').val() || ''}`
            + `&maxPrice=${$('input[name="maxPrice"]').val() || ''}`
            + `&minStock=${$('input[name="minStock"]').val() || ''}`
            + `&maxStock=${$('input[name="maxStock"]').val() || ''}`
            + `&orderBy=${orderBy}`
            + `&ascending=${ascending}`;
    }

    // Open card details modal overlay
    $(document).on('click', '.product-card-grid-item', function(e) {
        e.preventDefault();
        const productId = $(this).data('id');

        // Load the product partial via AJAX
        $.get(`/Product/get-product-partial/${productId}`)
            .done(function(html) {
                $('#productOverlay .modal-body').html(html);

                const modalEl = document.getElementById('productOverlay');
                const modal = new bootstrap.Modal(modalEl); 
                modal.show(); 
            })
            .fail(function() {
                alert('Failed to load product.');
            });
    });

    // Edit Product Modal events
    $(document).on('click', '.btn-edit-product', function (e) {
        e.preventDefault();
        e.stopPropagation();

        const productId = $(this).data('id');

        $.get(`/Product/get-edit-product-partial/${productId}`)
            .done(function (html) {
                $('#productOverlay .modal-body').html(html);

                const modalEl = document.getElementById('productOverlay');
                const modal = new bootstrap.Modal(modalEl);
                modal.show();

                const form = $('#editProductForm');
                const priceInput = form.find('input[name="Price"]');
                const stockInput = form.find('input[name="Stock"]');
                const priceError = form.find('#priceError');
                const stockError = form.find('#stockError');

                function isNumeric(value) {
                    return !isNaN(value) && value.trim() !== '';
                }

                form.off('submit').on('submit', function (e) {
                    e.preventDefault();

                    let valid = true;

                    if (!isNumeric(priceInput.val())) {
                        priceError.removeClass('d-none');
                        valid = false;
                    }
                    else if (parseFloat(priceInput.val()) <= 0) {
                        priceError.text("Price must be greater than 0.").removeClass('d-none');
                        valid = false;
                    }
                    else priceError.addClass('d-none');

                    if (!isNumeric(stockInput.val())) {
                        stockError.removeClass('d-none');
                        valid = false;
                    } else stockError.addClass('d-none');

                    if (!valid) 
                        return;

                    const formData = {
                        id: form.find('input[name="Id"]').val(),
                        name: form.find('input[name="Name"]').val(),
                        description: form.find('textarea[name="Description"]').val(),
                        price: parseFloat(priceInput.val()),
                        stock: parseInt(stockInput.val()),
                        imageURL: form.find('textarea[name="ImageURL"]').val()
                    };

                    fetch(`/Product/Update/${formData.id}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(formData)
                    })
                    .then(res => {
                        if (!res.ok) throw new Error();
                        return res.json();
                    })
                    .then(() => {
                        bootstrap.Modal.getInstance(modalEl).hide();
                        loadProducts(1);
                    })
                    .catch(() => alert('Update failed'));
                });
            })
            .fail(function () {
                alert('Failed to load edit form.');
            });
    });

    // Page Size Change
    $('#pageSize').on('change', function () {
        loadProducts(1);
    });

    // Filter Form
    $("#filterForm").submit(function (e) {
        e.preventDefault();
        loadProducts(1);
    });

    // Pagination Click
    $(document).on('click', '.pagination .page-link', function (e) {
        e.preventDefault();
        const page = parseInt($(this).data('page'));
        if (page && !isNaN(page)) {
            loadProducts(page);
        }
    });
</script>